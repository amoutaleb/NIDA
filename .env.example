# ============================================================
# NiDa — Environment Configuration
#
# Copy this file to `.env` and fill in your own API keys.
# The real `.env` is excluded from version control (see .gitignore);
# never commit real keys to a public repository.
#
# Free API keys can be obtained from:
#   NASA FIRMS      https://firms.modaps.eosdis.nasa.gov/api/map_key/
#   OpenWeatherMap  https://openweathermap.org/api  (free tier)
#   OpenRouteService https://openrouteservice.org/dev/#/signup
# Open-Meteo requires no key.
# ============================================================

# --- NASA FIRMS (active fire detections) ---
FIRMS_MAP_KEY=your_firms_map_key_here
FIRMS_BASE_URL=https://firms.modaps.eosdis.nasa.gov/api/area/csv
FIRMS_SOURCE=VIIRS_SNPP_NRT
# Number of days of detections to fetch per poll (3 is a sensible default).
FIRMS_DAY_RANGE=3

# --- Area of interest: Algeria bounding box (west,south,east,north) ---
ALGERIA_BBOX=-8.7,18.9,11.9,37.1

# --- Alerting ---
ALERT_RADIUS_KM=10
CRITICAL_RADIUS_KM=5
ADVISORY_RADIUS_KM=20

# --- Automated pipeline scheduler ---
FIRMS_POLL_INTERVAL_HOURS=3
SCHEDULER_ENABLED=true

# --- Data lifecycle ---
# Detections older than this many days are moved to the archive tables.
ACTIVE_RETENTION_DAYS=10

# --- Land cover filtering (MODIS MCD12C1) ---
# Filters desert/gas-flare false positives and tags vegetation type.
LANDCOVER_FILTER_ENABLED=true

# --- Persistence filter (self-learning industrial-source suppression) ---
PERSISTENCE_FILTER_ENABLED=true
PERSISTENCE_MIN_DISTINCT_DAYS=3
PERSISTENCE_LOOKBACK_DAYS=60
# A cell counts as industrial only if persistent AND low-intensity AND
# spatially isolated -- so a real spreading/intense fire is never dropped.
STATIC_MAX_FRP_MW=100
STATIC_MAX_NEIGHBOUR_CELLS=4

# --- Known industrial-source filter (OSM power plants, cement, refineries) ---
INDUSTRIAL_FILTER_ENABLED=true
INDUSTRIAL_FILTER_BUFFER_KM=3.0

# --- Database ---
DATABASE_URL=sqlite:///./nida.db

# --- Wind data (dual-source for directional alert ellipses) ---
OPENWEATHERMAP_API_KEY=your_openweathermap_key_here
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1/forecast
OPENWEATHERMAP_BASE_URL=https://api.openweathermap.org/data/2.5/weather

# --- Push notifications (Firebase Cloud Messaging) ---
# Optional: without a service-account file the system runs in dry-run mode
# (alerts are computed and logged but not actually dispatched).
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CREDENTIALS_PATH=./firebase_service_account.json

# --- Evacuation routing (OpenRouteService) ---
ORS_API_KEY=your_openrouteservice_key_here
ORS_BASE_URL=https://api.openrouteservice.org/v2/directions/driving-car/geojson
EVACUATION_CORRIDOR_BUFFER_KM=40
EVACUATION_MAX_AVOID_ZONES=15

# --- Application ---
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
